# Copy to `.env` and fill in real values. Loaded by sandbox.http via VS Code REST Client's
# {{$dotenv NAME}} syntax. Not read by the agent runtimes themselves — the session-create
# request injects the key as an agent option, which Coral forwards as an env var.

OPENROUTER_API_KEY=sk-or-v1-...

# Required. Used by all three agents to authenticate against Exa's hosted MCP server
# (https://mcp.exa.ai/mcp) for web_search_exa + web_fetch_exa research tools.
EXA_API_KEY=
