FROM gradle:8.14.2-jdk24 AS build
WORKDIR /home/gradle/src

# Copy project sources (module directory) into the build image
COPY --chown=gradle:gradle . /home/gradle/src

# Build a custom minimal JRE to reduce runtime size
RUN jlink \
    --verbose \
    --add-modules java.base,jdk.unsupported,java.desktop,java.instrument,java.logging,java.management,java.sql,java.xml,java.naming,jdk.crypto.ec \
    --compress 2 --strip-debug --no-header-files --no-man-pages \
    --output /opt/minimal-java

# Build a runnable distribution with start scripts (skip tests for faster images)
RUN gradle installDist --no-daemon -x test

FROM ubuntu:jammy

# Install minimal runtime dependencies
RUN apt-get update \
    && apt-get install -y --no-install-recommends libudev1 ca-certificates \
    && rm -rf /var/lib/apt/lists/*

ENV JAVA_HOME=/opt/minimal-java
ENV PATH="$JAVA_HOME/bin:$PATH"

WORKDIR /app

# Copy the custom minimal JRE from the builder stage
COPY --from=build "$JAVA_HOME" "$JAVA_HOME"

# Copy the built application distribution and agent config
# The Application plugin's installDir can vary with applicationName; use a wildcard to be robust.
COPY --from=build /home/gradle/src/build/install/*/ /app/
COPY --from=build /home/gradle/src/coral-agent.toml /app/coral-agent.toml

# Ensure a stable start-script name regardless of the generated applicationName
RUN set -eux; \
    if [ ! -d /app/bin ]; then \
      echo "No /app/bin directory after copying distribution. Contents of /app:"; ls -la /app; exit 1; \
    fi; \
    script="$(ls -1 /app/bin/* 2>/dev/null | head -n 1 || true)"; \
    if [ -z "$script" ]; then \
      echo "No start script found under /app/bin. Contents:"; ls -la /app/bin; exit 1; \
    fi; \
    ln -sf "$script" /app/bin/agent

# Use an unprivileged user
RUN useradd -r -u 1000 -g root appuser \
    && chown -R appuser:root /app
USER appuser

# Use the generated start script from the Gradle application plugin
ENTRYPOINT ["/app/bin/agent"]
